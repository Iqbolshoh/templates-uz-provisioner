# Shared secret — must match Templates.uz's PROVISIONER_TOKEN exactly.
# Generate with: php -r "echo bin2hex(random_bytes(32));"
PROVISIONER_TOKEN=

# Where /var/www/customers/{subdomain}/ directories are created.
PROVISIONER_CUSTOMERS_ROOT=/var/www/customers

# MySQL connection used ONLY for creating/dropping project databases + users.
# This user needs CREATE, CREATE USER, and GRANT OPTION — it does NOT need to
# be root, and should be a DIFFERENT user than the one Templates.uz itself
# connects with (that one should never have these privileges).
PROVISIONER_DB_HOST=127.0.0.1
PROVISIONER_DB_PORT=3306
PROVISIONER_DB_USERNAME=
PROVISIONER_DB_PASSWORD=

# Admission control — total RAM (MB) / CPU (%, 100 = one core) this host will
# ever commit across every dynamic project combined. A new /provision request
# that would push the total over either number is rejected with a clear
# error instead of silently overcommitting the machine. Leave both at 0 (or
# unset) to disable this check entirely. See server.md section 0 for how to
# size these for a specific server's real RAM/CPU.
PROVISIONER_MAX_TOTAL_RAM_MB=0
PROVISIONER_MAX_TOTAL_CPU_PERCENT=0
