# Shared secret — must match Templates.uz's PROVISIONER_TOKEN exactly.
# Generate with: php -r "echo bin2hex(random_bytes(32));"
PROVISIONER_TOKEN=

# Where /var/www/customers/{subdomain}/ directories are created.
PROVISIONER_CUSTOMERS_ROOT=/var/www/customers

# MySQL connection used ONLY for creating/dropping project databases + users.
# This user needs CREATE, CREATE USER, and GRANT OPTION — it does NOT need to
# be root, and should be a DIFFERENT user than the one Templates.uz itself
# connects with (that one should never have these privileges).
PROVISIONER_DB_HOST=127.0.0.1
PROVISIONER_DB_PORT=3306
PROVISIONER_DB_USERNAME=
PROVISIONER_DB_PASSWORD=

# Admission control — total RAM (MB) / CPU (%, 100 = one core) this host will
# ever commit across every dynamic project combined. A new /provision request
# that would push the total over either number is rejected with a clear
# error instead of silently overcommitting the machine. Leave both unset (or
# 0) to auto-detect a safe default (75% of this host's real RAM/CPU, reserving
# the rest for the OS + the main site's own stack — see server.md section 0).
# Set BOTH to -1 to disable admission control entirely (not recommended).
PROVISIONER_MAX_TOTAL_RAM_MB=0
PROVISIONER_MAX_TOTAL_CPU_PERCENT=0

# Directory for the advisory lock file that serializes the budget-check +
# container-creation critical section across concurrent PHP-FPM workers
# (prevents two simultaneous /provision requests from both squeezing past
# the budget check before either container exists). Must be writable by
# this process's OS user. Defaults to the system temp directory.
# PROVISIONER_LOCK_DIR=/var/lib/templates-uz-provisioner

# Directory holding one JSON file per subdomain recording which database +
# user /database created for it — consulted (never the caller) by /destroy's
# drop_database, so a caller can only ask "drop this subdomain's database if
# it has one," never name an arbitrary database (see README's "Database
# records"). Must persist across reboots and be writable by this process's
# OS user. Defaults next to PROVISIONER_LOCK_DIR / the system temp directory.
# PROVISIONER_DB_REGISTRY_DIR=/var/lib/templates-uz-provisioner/db-registry

# ── Nginx automation (see README.md "Nginx automation setup") ─────────────
# Directory this process writes per-project vhost files into. Must be owned
# (or group-writable) by the OS user this Provisioner runs as — NOT
# /etc/nginx/conf.d directly. Included into the main Nginx config via a
# one-time `include` line you add yourself (see README.md).
PROVISIONER_NGINX_CONF_DIR=/etc/nginx/conf.d/templates-uz-dynamic

# Domain dynamic projects are served under: {subdomain}.<this value>.
PROVISIONER_PROJECTS_DOMAIN=templates.uz

# Path to the wildcard cert directory already set up for static projects
# (see NGINX.md) — reused as-is, no per-subdomain certbot call needed.
PROVISIONER_WILDCARD_CERT_DIR=/etc/letsencrypt/live/templates.uz-wildcard

# Shared Nginx rate-limit zone for ALL dynamic projects (requests/minute per
# subdomain) — vanilla Nginx can't vary this per-plan without Nginx Plus or
# OpenResty/Lua, so every dynamic project gets the same limit. Defaults to
# matching PROJECTS_RATE_PER_MINUTE's own default (300).
PROVISIONER_DYNAMIC_RATE_PER_MINUTE=300

# `nginx -t` / reload are run via `sudo -n` by default (narrow sudoers rule
# — see README.md). Set to 1 only if this process already runs as root or
# you've wrapped reload differently.
PROVISIONER_NGINX_NO_SUDO=0

# Override if your reload command differs (e.g. `nginx -s reload` instead of
# systemd). Must be a single string; split on spaces, no shell quoting.
# PROVISIONER_NGINX_RELOAD_COMMAND=systemctl reload nginx
